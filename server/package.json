{
  "name": "prepdost-server",
  "version": "1.0.0",
  "description": "PrepDost Backend API",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rmdir /s /q dist"
  },
  "keywords": [
    "prepdost",
    "express",
    "typescript",
    "mongodb",
    "jwt"
  ],
  "author": "Tejas Kumar",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
